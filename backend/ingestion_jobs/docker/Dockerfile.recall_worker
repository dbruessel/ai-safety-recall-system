# backend/ingestion_jobs/docker/Dockerfile.recall_worker
FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir --upgrade pip

COPY ../../requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY .. /app/ingestion_jobs

# recall_worker reads CLOUD_RUN_TASK_INDEX / CLOUD_RUN_TASK_COUNT
CMD ["python", "-m", "ingestion_jobs.recall_worker"]
