# backend/ingestion_jobs/docker/Dockerfile.recall_worker
FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir --upgrade pip

# Install dependencies
COPY backend/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

# Copy ONLY the ingestion_jobs folder (your worker lives here)
COPY backend/ingestion_jobs /app/ingestion_jobs

# Run the recall worker script
CMD ["python", "ingestion_jobs/recall_worker/recall_worker.py"]
